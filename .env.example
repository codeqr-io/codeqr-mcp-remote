# Required: Public URL where this server is accessible
SERVER_URL=https://mcp.codeqr.io

# Port to listen on (default: 3000)
PORT=3000

# Optional: Stainless API key for code execution sandbox
STAINLESS_API_KEY=

# Log level: debug, info, warn, error (default: info)
LOG_LEVEL=info

# Upstash Redis (recommended for Vercel / serverless — persistent OAuth state)
# Create a database at https://upstash.com and copy REST URL + token from the console.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
